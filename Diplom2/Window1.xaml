<Window x:Class="Diplom2.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Diplom2"
        mc:Ignorable="d"
        Title="Главное Окно" Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="#2C3E50" Padding="15,12">
            <Grid>
                <TextBlock Text="Главная" Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock x:Name="txtOwnerFio" Text="Иванов И.И." Foreground="White" FontSize="14" TextAlignment="Right"/>
                    <TextBlock x:Name="txtAddress" Text="ул. Ленина, 5, кв. 42" Foreground="#B0C4DE" FontSize="12" TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Баланс -->
                <Border Background="White" CornerRadius="12" Padding="16"
                       Margin="0,0,0,12">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Текущий баланс" Foreground="#606266" FontSize="14"/>
                            <TextBlock x:Name="txtBalance" Text="−2 450 ₽" Foreground="#E74C3C" FontSize="24" FontWeight="Bold"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button x:Name="btnPaymentHistory" Content="История платежей" Width="160" Height="36"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                                Foreground="#2C3E50" FontWeight="SemiBold" FontSize="13"
                                Cursor="Hand" Click="BtnPaymentHistory_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8" Padding="8,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Заявки -->
                <TextBlock Text="Мои последние заявки" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,10"/>

                <!-- Динамический список заявок -->
                <ItemsControl x:Name="lstRequests" Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayText}"/>
                                        <TextBlock Foreground="#6B7280" FontSize="12" Margin="0,3,0,0"
                                                   Text="{Binding DisplayDate}"/>
                                    </StackPanel>
                                    <!-- Плашка статуса -->
                                    <Border Background="{Binding StatusColor}" CornerRadius="20" Padding="6,2"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" 
                                                   Foreground="{Binding StatusForeground}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Кнопки действий -->
                <Button x:Name="btnSubmitReadings" Content="Передать показания" Height="40" Background="#3498DB" Foreground="White"
                        FontWeight="SemiBold" FontSize="14" BorderThickness="0"
                        Margin="0,15,0,5" Cursor="Hand" Click="BtnSubmitReadings_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="btnCreateRequest" Content="Создать заявку" Height="40" Background="White" BorderBrush="#BDC3C7"
                        BorderThickness="1" Foreground="#2C3E50" FontWeight="SemiBold"
                        FontSize="14" Margin="0,0,0,10" Cursor="Hand" Click="BtnCreateRequest_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="12,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>