<Window x:Class="Diplom2.Window4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор типа заявки -->
        <TextBlock Grid.Row="0" Text="Тип заявки:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbRequestType" Grid.Row="1" Height="30"
                  DisplayMemberPath="name" SelectedValuePath="type_id"
                  Margin="0,0,0,15"/>

        <!-- Описание заявки -->
        <TextBlock Grid.Row="2" Text="Описание проблемы:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtDescription" Grid.Row="2" TextWrapping="Wrap"
                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 MinHeight="120" Margin="0,25,0,15"
                 BorderBrush="#BDC3C7" BorderThickness="1"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0"
                    Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                    Foreground="#2C3E50" FontWeight="SemiBold" Cursor="Hand"
                    Click="BtnCancel_Click"/>
            <Button Content="Отправить" Width="100" Height="35"
                    Background="#3498DB" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnSubmit_Click"/>
        </StackPanel>
    </Grid>
</Window>